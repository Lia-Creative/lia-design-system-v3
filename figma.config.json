{
  "codeConnect": {
    "include": ["src/components/**/*", "src/figma/**/*"],
    "exclude": ["src/components/ui/*.stories.tsx"],
    "parser": "react",
    "importPaths": {
      "components/ui/*": "@/components/ui",
      "lib/*": "@/lib"
    },
    "paths": {
      "@/components/ui": ["src/components/ui"],
      "@/lib": ["src/lib"]
    },
    "documentUrlSubstitutions": {
      "<FIGMA_FILE>": "https://www.figma.com/design/IOEnlvI5WiSDF4zjghA2AN/Lia-Design-System--shadcn-studio-"
    }
  }
}
